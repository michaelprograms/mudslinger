{
  "name": "mudslinger-browser",
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node tools/postinstall.js",
    "build": "node tools/genAppInfo.js `git rev-parse HEAD` && tsc -p tsconfig.json && webpack && node tools/buildDocs.js",
    "build-dev": "node tools/genAppInfo.js `git rev-parse HEAD` && tsc -p tsconfig.json && webpack --mode=development && node tools/buildDocs.js",
    "build-docs": "node tools/buildDocs.js",
    "start": "npx http-server static/public -p 5000",
    "build-test": "tsc -p tsconfig.test.json && webpack --config webpack.config.test.js",
    "build-test-output": "tsc -p tsconfig.test.json && webpack --config webpack.config.test_output.js"
  },
  "dependencies": {
    "codemirror": "^5.24.2",
    "fs-extra": "^11",
    "jquery": "^2.2.4",
    "jqwidgets-framework": "^9.1.6"
  },
  "devDependencies": {
    "@types/jquery": "^2.0.68",
    "@types/qunit": "^2.19.14",
    "html-webpack-plugin": "^5",
    "markdown-it": "^14",
    "qunit": "^2.26.0",
    "typescript": "^5",
    "webpack": "^5",
    "webpack-cli": "^5"
  }
}
