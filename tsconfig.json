{
    "compilerOptions": {
        "rootDir": ".",
        "strict": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "isolatedModules": true,
        "lib": [
            "DOM",
            "ES6",
            "DOM.Iterable",
            "ScriptHost"
        ],
        "types": [
            "jquery"
        ]
    },
    "exclude": [
        "node_modules"
    ],
    "include": [
        "./src/ts/*",
        "./test/**/*",
        "./vite.config.ts"
    ]
}
